# ============================================
# Tribal AI — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=production
ALLOWED_ORIGIN=https://yourdomain.com

# --- Security ---
JWT_SECRET=your-super-secret-jwt-key-here

# --- Database (optional — runs in-memory without it) ---
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/tribal-ai

# --- Admin Credentials ---
ADMIN_EMAIL=obasanjosamuel404@gmail.com
ADMIN_PASSWORD=Obasanjo444@@

# --- AI Providers (at least one required for chat) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# --- Payment (Paystack for Nigerian payments) ---
PAYSTACK_SECRET=sk_live_...

# --- Google OAuth (for sign-in with Google) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Web Search (for AI browsing) ---
WEB_SEARCH_API=tvly-...  # Tavily API key

# --- Plan Limits ---
FREE_MONTHLY_LIMIT=50
PRO_MONTHLY_LIMIT=9999

# --- Frontend ---
VITE_API_URL=http://localhost:3000
